{
  "name": "@ekehi/explorer-backend",
  "version": "0.1.0",
  "description": "Ekehi Network block explorer backend — indexer + REST API + WebSocket push",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
